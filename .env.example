# Environment Configuration
NODE_ENV=production

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Chatbot Optimization Settings (Optional - defaults are set in code)
CHAT_MAX_TOKENS=150
CHAT_TEMPERATURE=0.3
CHAT_RATE_LIMIT_REQUESTS=10
CHAT_RATE_LIMIT_WINDOW=60000
CHAT_CACHE_DURATION=300000

# Database (if using)
DATABASE_URL=your_database_url_here

# Authentication (if using)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-domain.com

# External APIs
FIGMA_ACCESS_TOKEN=your_figma_token_here

# Analytics (optional)
GOOGLE_ANALYTICS_ID=your_ga_id_here

# Email Service (if using)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CACHE_COMPONENTS=true
ENABLE_CHAT_CACHING=true
ENABLE_CHAT_RATE_LIMITING=true